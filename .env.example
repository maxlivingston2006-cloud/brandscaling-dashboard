# Copy to .env and fill in. Never commit your real .env.
PORT=3000

# ── Google Places (lead scraping) ──
GOOGLE_PLACES_API_KEY=

# ── Gmail API (send + reply detection) ──
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=
GMAIL_REFRESH_TOKEN=          # set automatically after visiting /auth once

# ── Sender / brand identity (shown on emails, invoices, reports) ──
SENDER_NAME=Your Name
SENDER_PHONE=(555) 000-0000
COMPANY_NAME=Your Agency
COMPANY_WEBSITE=https://example.com
COMPANY_LOCATION=Your City, ST
COMPANY_TAGLINE=Performance Marketing
CONTACT_EMAIL=hello@example.com

# ── Dashboard auth (Basic Auth) ──
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme

# ── Optional ──
# ANTHROPIC_API_KEY=          # AI features; normally set in dashboard Settings instead
# DATABASE_PATH=/data/leads.db  # persistent volume path in production
# DISABLE_AUTH=true           # LOCAL DEV ONLY — never set in production
